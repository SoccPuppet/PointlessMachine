    "fabric-datagen": [
      "org.sable.pointless_machine.client.Pointless_machineDataGenerator"
    ],
    "client": [
      "org.sable.pointless_machine.client.Pointless_machineClient"
    ],
    "main": [
      "org.sable.pointless_machine.Pointless_machine"
