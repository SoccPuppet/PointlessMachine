{
  "schemaVersion": 1,
  "id": "pointless_machine",
  "version": "1.0.67",
  "name": "Pointless Machine",
  "description": "Adds many pointless patterns.",
  "authors": [],
  "contact": {},
  "license": "All-Rights-Reserved",
  "icon": "assets/pointless_machine/icon.png",
  "environment": "*",
